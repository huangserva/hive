# HippoTeam relay — Nginx 反代 + certbot（Caddy 的替代方案）
# 1) 先装证书： sudo certbot --nginx -d aliyun.servasyy.com
#    （certbot 会自动改写 listen 443 ssl 段并配置续期 timer。）
# 2) 关键是下面的 Upgrade/Connection 头，否则 WebSocket 握手会 400。
# 3) sudo nginx -t && sudo systemctl reload nginx

map $http_upgrade $connection_upgrade {
	default upgrade;
	''      close;
}

server {
	listen 443 ssl;
	server_name aliyun.servasyy.com;

	# 这两行由 certbot 自动填；手动配则指向 /etc/letsencrypt/live/aliyun.servasyy.com/
	ssl_certificate     /etc/letsencrypt/live/aliyun.servasyy.com/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/aliyun.servasyy.com/privkey.pem;

	location / {
		proxy_pass http://127.0.0.1:8787;
		proxy_http_version 1.1;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection $connection_upgrade;
		proxy_set_header Host $host;
		proxy_set_header X-Forwarded-For $remote_addr;
		proxy_read_timeout 3600s;
		proxy_send_timeout 3600s;
	}
}

server {
	listen 80;
	server_name aliyun.servasyy.com;
	return 301 https://$host$request_uri;
}
